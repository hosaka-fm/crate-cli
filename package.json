{
  "name": "@hosaka-fm/crate-cli",
  "version": "0.2.0",
  "description": "crate \u2014 the command-line door to the crate music-data API (agents-first, clig.dev-aligned)",
  "license": "MIT",
  "repository": "github:hosaka-fm/crate-cli",
  "type": "module",
  "bin": {
    "crate": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18.17"
  },
  "scripts": {
    "prepare": "npm run build",
    "build": "tsc -p tsconfig.build.json && node -e \"require('fs').chmodSync('dist/index.js', 0o755)\"",
    "typecheck": "tsc --noEmit",
    "pretest": "npm run build",
    "test": "vitest run",
    "gen:types": "openapi-typescript contracts/spec.json -o src/generated/crate-api.ts",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build",
    "gen:spec": "curl -fsS https://crate.hosaka.fm/api/v2/openapi.json | jq . > contracts/spec.json"
  },
  "dependencies": {
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "openapi-typescript": "^7.4.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
